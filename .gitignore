# Binaries (general)
*.exe~
*.dll
*.so
*.dylib

# Exclude .exe by default, but allow pre-built tool binaries
*.exe
!tools/proxy-web/proxy-web.exe
!tools/vmware-sandbox/vmrun-wrapper/vmrun-wrapper.exe
!tools/vmware-sandbox/memdump-racer/memdump-racer.exe
!tools/vmware-sandbox/tiny-unpack/tiny-unpack.exe
!tools/vmware-sandbox/decrypt-tool/decrypt-tool.exe
!tools/vmware-sandbox/sandbox-evasion-check/sandbox-evasion-check.exe
!tools/vmware-sandbox/vm-detect-checker/vm-detect-checker.exe

# Test binary
*.test

# Coverage
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace
go.work
go.work.sum

# Environment
.env

# Editor/IDE
.idea/
.vscode/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Quarantine (encrypted malware files)
tools/proxy-web/Quarantine/

# Analysis output (generated files)
tools/ghidra-headless/output/*
!tools/ghidra-headless/output/.gitkeep
tools/vmware-sandbox/output/*
!tools/vmware-sandbox/output/.gitkeep

# Logs
tools/proxy-web/logs/*
!tools/proxy-web/logs/.gitkeep
tools/ghidra-headless/logs/*
!tools/ghidra-headless/logs/.gitkeep
tools/vmware-sandbox/logs/*
!tools/vmware-sandbox/logs/.gitkeep

# Analysis reports (optional, uncomment to ignore)
# reports/

# Input binaries (don't commit malware samples)
tools/ghidra-headless/input/*
!tools/ghidra-headless/input/.gitkeep
tools/vmware-sandbox/input/*
!tools/vmware-sandbox/input/.gitkeep

# YARA rules (downloaded, not committed)
tools/ghidra-headless/yara-rules/*
!tools/ghidra-headless/yara-rules/.gitkeep

# OS
Thumbs.db
.DS_Store
