# Binaries (general)
*.exe~
*.dll
*.so
*.dylib

# Exclude .exe by default, but allow pre-built tool binaries
*.exe
!tools/malware-fetch/malware-fetch.exe
!tools/malware-sandbox/vmrun-wrapper/vmrun-wrapper.exe
!tools/malware-sandbox/memdump-racer/memdump-racer.exe
!tools/malware-sandbox/tiny-unpack/tiny-unpack.exe
!tools/malware-sandbox/decrypt-tool/decrypt-tool.exe
!tools/malware-sandbox/sandbox-evasion-check/sandbox-evasion-check.exe
!tools/malware-sandbox/vm-detect-checker/vm-detect-checker.exe

# Test binary
*.test

# Coverage
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace
go.work
go.work.sum

# Environment
.env

# Editor/IDE
.idea/
.vscode/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# Quarantine (encrypted malware files)
tools/malware-fetch/Quarantine/

# Analysis output (generated files)
tools/ghidra-headless/output/*
!tools/ghidra-headless/output/.gitkeep
tools/malware-sandbox/output/*
!tools/malware-sandbox/output/.gitkeep

# Logs
tools/malware-fetch/logs/*
!tools/malware-fetch/logs/.gitkeep
tools/ghidra-headless/logs/*
!tools/ghidra-headless/logs/.gitkeep
tools/malware-sandbox/logs/*
!tools/malware-sandbox/logs/.gitkeep

# GUI prototype test/runtime artifacts (may leak host paths)
tools/gui-prototype/test_out.txt
tools/gui-prototype/uploads/

# Analysis reports (optional, uncomment to ignore)
# reports/

# Input binaries (don't commit malware samples)
tools/ghidra-headless/input/*
!tools/ghidra-headless/input/.gitkeep
tools/malware-sandbox/input/*
!tools/malware-sandbox/input/.gitkeep

# YARA rules (downloaded, not committed)
tools/ghidra-headless/yara-rules/*
!tools/ghidra-headless/yara-rules/.gitkeep

# OS
Thumbs.db
.DS_Store

# Skill registry: cc-re-toolkit is its own source of truth.
# sync-skills assumes a one-way sync from ~/.claude/skills, which we don't
# use here — so don't track it (would just churn on every `cp` from life).
.claude/skills/sync-skills/

# Local Claude Code settings (per-project state, not for sharing)
.claude/settings.local.json
