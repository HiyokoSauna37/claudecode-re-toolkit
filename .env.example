# ===========================================
# cc-malware-toolkit Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# .env is gitignored and will not be committed.

# --- Quarantine Encryption ---
# Password for AES-256-CBC encryption of downloaded malware
QUARANTINE_PASSWORD=changeme

# --- API Keys ---
# VirusTotal API key (free tier works)
VIRUSTOTAL_API_KEY=

# abuse.ch API key (shared by MalwareBazaar / ThreatFox / URLHaus)
# Required from late 2025 for all three services.
ABUSECH_AUTH_KEY=

# --- threat-intel skill: extra OSINT services (all optional) ---
# Sources: see .claude/skills/threat-intel/references/api-keys-guide.md
ALIENVAULT_API_KEY=
HYBRID_ANALYSIS_API_KEY=
TRIAGE_API_KEY=
URLSCANIO_API_KEY=
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
GREYNOISE_API_KEY=
IPINFO_API_KEY=
VULNCHECK_API_KEY=
NIST_API_KEY=
MALSHARE_API_KEY=
MALPEDIA_API_KEY=

# --- VMware Sandbox ---
# Path to vmrun executable
# Windows: C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe
# Linux: /usr/bin/vmrun
# macOS: /Applications/VMware Fusion.app/Contents/Library/vmrun
VMRUN_PATH=

# Path to the VM's .vmx file
VM_VMX_PATH=

# Guest OS credentials
VM_GUEST_USER=
VM_GUEST_PASS=

# Guest OS user profile directory (e.g., C:\Users\<username>)
VM_GUEST_PROFILE=

# Clean snapshot name (must match an existing VMware snapshot)
# sandbox.sh default: clean_with_tools_fakenet_ca
VM_SNAPSHOT=clean_with_tools_fakenet_ca

# vmrun command timeout in seconds (default: 120)
# 30s is too short for large file copies or process listing on loaded VMs.
# Recommended: 120 for normal use, 300 for >50MB files or complex guest operations.
VMRUN_TIMEOUT=120
