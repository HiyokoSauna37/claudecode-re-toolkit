# ===========================================
# cc-malware-toolkit Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# .env is gitignored and will not be committed.

# --- Quarantine Encryption ---
# Password for AES-256-CBC encryption of downloaded malware
QUARANTINE_PASSWORD=changeme

# --- API Keys ---
# VirusTotal API key (free tier works)
VIRUSTOTAL_API_KEY=

# abuse.ch API key (MalwareBazaar / ThreatFox)
# Optional: bazaar/threatfox commands work without it but with rate limits
ABUSECH_AUTH_KEY=

# --- VMware Sandbox ---
# Path to vmrun executable
# Windows: C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe
# Linux: /usr/bin/vmrun
# macOS: /Applications/VMware Fusion.app/Contents/Library/vmrun
VMRUN_PATH=

# Path to the VM's .vmx file
VM_VMX_PATH=

# Guest OS credentials
VM_GUEST_USER=
VM_GUEST_PASS=

# Guest OS user profile directory (e.g., C:\Users\<username>)
VM_GUEST_PROFILE=

# Clean snapshot name (default: clean_with_tools)
VM_SNAPSHOT=clean_with_tools

# vmrun command timeout in seconds (default: 30)
VMRUN_TIMEOUT=30
